# ── Tradovate (LEADER account) credentials ─────────────────────── #
# Get the API key (cid + sec) from:
#   https://trader.tradovate.com/welcome  →  API Access
TRADOVATE_USERNAME=
TRADOVATE_PASSWORD=
TRADOVATE_APP_ID=TradeSynchronizer
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=
TRADOVATE_SEC=

# 'demo' or 'live' — must match the environment where your LEADER
# account on TradeSyncer is configured.
TRADOVATE_ENVIRONMENT=demo

# Optional: pin the account ID. If empty, the first account from
# /account/list is used.
TRADOVATE_ACCOUNT_ID=

# ── mitmproxy listening port (TradingView Desktop must be launched
# with --proxy-server=127.0.0.1:8080) ──────────────────────────── #
PROXY_LISTEN_HOST=127.0.0.1
PROXY_LISTEN_PORT=8080

# ── Replication policy ─────────────────────────────────────────── #
# 'mirror' = same orderType as IBKR (Market/Limit/Stop/StopLimit)
# 'market' = always send a Market order on Tradovate, regardless of
#            the IBKR order type. Faster sync, no missed fills, but
#            ignores limit/stop prices.
REPLICATION_MODE=mirror

# When true, replicate only orders that OPEN or REVERSE positions.
# Stop / stop-limit orders (typically protective on the IBKR side)
# are skipped. Recommended ON for a position-mirroring tool.
SKIP_PROTECTIVE_STOPS=true

# Comma-separated IBKR account IDs to watch. Empty = watch all.
# Useful when the user has both a live and a paper IBKR account
# connected in TradingView and only wants one of them mirrored.
IBKR_WATCHED_ACCOUNTS=

# ── Logging ────────────────────────────────────────────────────── #
LOG_LEVEL=INFO
LOG_FILE=/tmp/tradesync.log
