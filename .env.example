# =====================================================================
# TradeSynchronizer environment template
# ---------------------------------------------------------------------
# Copy this file to BOTH:
#     .env.demo   (TRADOVATE_ENVIRONMENT=demo)
#     .env.live   (TRADOVATE_ENVIRONMENT=live)
# and fill in the values for each environment. Those two files hold
# real secrets and are gitignored; this template is the only one
# committed. Values below are PLACEHOLDERS, not real credentials.
#
# A few global-only settings (LOG_LEVEL, PROXY_LISTEN_HOST, ...) may
# instead live in a plain `.env` shared across environments; they are
# listed at the bottom and are optional.
# =====================================================================

# --- Which environment this file configures -------------------------
# 'demo' or 'live'. MUST differ between .env.demo and .env.live.
TRADOVATE_ENVIRONMENT=demo

# --- Tradovate credentials (SECRET) ---------------------------------
TRADOVATE_USERNAME=your_tradovate_username
TRADOVATE_PASSWORD=your_tradovate_password
# The Tradovate LEADER account. You may write EITHER the internal numeric
# id (e.g. 1234567) OR the account NAME shown in the Tradovate UI —
# numeric or alphanumeric (e.g. DEMO3701228). The engine resolves a name
# to the internal id at startup via /account/list, so use whichever value
# you can see. (NOT the username.) Edited by hand here; the GUI no longer
# manages this field.
TRADOVATE_ACCOUNT_ID=your_account_id_or_name
TRADOVATE_DEVICE_ID=your_device_id

# --- Tradovate API app credentials (SECRET) -------------------------
# The cid/sec pair and app identity for the Tradovate API. If these are
# baked into tradesync/_app_credentials.py instead, they can be left
# blank here (env values, when present, take precedence).
TRADOVATE_SEC=your_tradovate_api_secret
TRADOVATE_CID=your_tradovate_api_cid
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_VERSION=1.0

# --- IBKR ------------------------------------------------------------
# Comma-separated IBKR account ids to observe (legacy watch list; the
# replication.json pairs are the primary source of truth now).
IBKR_WATCHED_ACCOUNTS=

# --- Proxy -----------------------------------------------------------
# Port the mitmproxy listener binds to. Use a DIFFERENT port for demo
# vs live if you ever run both at once (e.g. 8081 demo / 8080 live).
PROXY_LISTEN_PORT=8080


# =====================================================================
# Optional global settings (may live in a shared plain `.env`).
# All have sensible defaults in code; uncomment only to override.
# =====================================================================
# Set 'true' only for a genuinely automated/headless Tradovate session.
#TRADOVATE_IS_AUTOMATED=false
# Host the proxy binds to (default 127.0.0.1).
#PROXY_LISTEN_HOST=127.0.0.1
# Auto-open TradingView Desktop on start.
#AUTO_LAUNCH_TRADINGVIEW=false
# Logging.
#LOG_LEVEL=INFO
#LOG_FILE=
#VERBOSE_TROUBLESHOOTING=true
