# TradeSynchronizer configuration template.
# Copy to .env and fill in (or launch TradeSynchronizer.app and use
# the Settings tabs — the GUI auto-creates and rewrites .env).
#
# Each Tradovate environment (LIVE and DEMO) runs as an independent
# engine on its own port; both can be active at the same time. The
# UI exposes per-env credentials in dedicated tabs, plus a "General"
# tab for the settings shared across both engines.

# Default environment for CLI mode (`python main.py` directly). The
# GUI starts each engine with an explicit env override and ignores
# this value.
TRADOVATE_ENVIRONMENT=demo

# ── Tradovate application (shared across environments) ────────── #
TRADOVATE_APP_ID=TradeSynchronizer
TRADOVATE_APP_VERSION=1.0

# ── LIVE environment ───────────────────────────────────────────── #
# Get the API key (cid + sec) from:
#   https://trader.tradovate.com/welcome  →  API Access
TRADOVATE_USERNAME_LIVE=
TRADOVATE_PASSWORD_LIVE=
TRADOVATE_CID_LIVE=
TRADOVATE_SEC_LIVE=
TRADOVATE_ACCOUNT_ID_LIVE=
PROXY_LISTEN_PORT_LIVE=8080
IBKR_WATCHED_ACCOUNTS_LIVE=

# ── DEMO environment ───────────────────────────────────────────── #
TRADOVATE_USERNAME_DEMO=
TRADOVATE_PASSWORD_DEMO=
TRADOVATE_CID_DEMO=
TRADOVATE_SEC_DEMO=
TRADOVATE_ACCOUNT_ID_DEMO=
PROXY_LISTEN_PORT_DEMO=8081
IBKR_WATCHED_ACCOUNTS_DEMO=

# ── Proxy server (shared host — ports are per-env above) ──────── #
# Point TradingView Desktop at the engine you want to feed:
#   --proxy-server=PROXY_LISTEN_HOST:<LIVE-or-DEMO port>
PROXY_LISTEN_HOST=127.0.0.1

# ── Replication policy ─────────────────────────────────────────── #
# 'mirror' = same orderType as IBKR (Market/Limit/Stop/StopLimit)
# 'market' = always send a Market order on Tradovate, regardless of
#            the IBKR order type. Faster sync, no missed fills, but
#            ignores limit/stop prices.
REPLICATION_MODE=mirror

# When true, replicate only orders that OPEN or REVERSE positions.
# Stop / stop-limit orders (typically protective on the IBKR side)
# are skipped. Recommended ON for a position-mirroring tool.
SKIP_PROTECTIVE_STOPS=true

# ── Logging ────────────────────────────────────────────────────── #
# Both engines write to the same file with [LIVE] / [DEMO] tags in
# every line so the combined log stays unambiguous.
LOG_LEVEL=INFO
LOG_FILE=/tmp/tradesync.log
